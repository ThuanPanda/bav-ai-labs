# The "resources" env layer — every var except NODE_ENV.
# Copy to apps/api/venv/.env.${NODE_ENV}, e.g. apps/api/venv/.env.dev
# Loaded after apps/api/.env by loadEnv('api') / DynamicConfigModule.

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=debug

# ─── Database (Drizzle / node-postgres) ─────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nestjs_mep
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=5m
DB_CONNECT_TIMEOUT=30s
