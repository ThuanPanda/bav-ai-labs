{
  "name": "@thuanpanda/bv",
  "version": "0.2.1",
  "description": "Bavaan internal CLI — skills, tools, and more",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThuanPanda/bav-ai-labs.git"
  },
  "bin": {
    "bv": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build",
    "prepare": "husky"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "bavaan",
    "cli",
    "skills"
  ],
  "author": "Bavaan",
  "license": "UNLICENSED",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.9",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
